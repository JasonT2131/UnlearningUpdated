wmdp = (Path(__file__).parent.parent / "wmdp").resolve()import click
import subprocess
from pathlib import Path

TOFU_DIR = Path(__file__).resolve().parent / "open-unlearning"

@click.group()
def cli():
    """TOFU Benchmark CLI"""
    pass

@cli.command()
@click.option("--config-name", default = "train.yaml", help = "Config to use")
@click.option("--experiment", default = "unlearn/tofu/default" , help = "Experiment to use")
@click.option("--forget_split", default = "forget10" )
@click.option("--retain_split", default = "retain90" )
@click.option("--trainer", default = "GradAscent" , help = "Unlearning Method")
@click.option("--task_name", default = "Sample_train" , help = "taskname")

def unlearn_tofu(config, experiment, forget, retain, trainer, taskname):
    """Run TOFU unlearning"""
    click.echo( f"Running unlearning for {taskname}")
    command = [
        "python src/train.py",
        "--config-name=", config,
        "--experiment=", experiment,
        "--forget_split", forget,
        "--retain_split",retain,
        "--trainer",trainer,
        "--taskname=", taskname
    ]
    subprocess.run(command, cwd=TOFU_DIR)


@cli.command()
@click.option("--config-name", required = True, help = "Config to use")
@click.option("--experiment", default = "eval/tofu/llama2" , help = "Experiment to use")
@click.option('--model', default = "Llama-3.2-1B-Instruct", help='model to use')
@click.option("--pretrained_model", help = "Pretrained model")
def evaluate_tofu(config, experiment, model, pretrained,taskname):
    """Evaluate model on TOFU benchmark"""
    click.echo(f"Evaluating model: {model}")
    command = [
        "python src/eval.py",
        "--config-name=",config,
        "--experiment=", experiment,
        "--model=",model,
        "model.model_args.pretrained_model_name_or_path", pretrained,
        "--taskname=", taskname
    ]
    subprocess.run(command, cwd=TOFU_DIR)

@cli.command()
@click.option("--config-name", required = True, help = "Config to use")
@click.option("--experiment", default = "eval/muse/llama2", help = "Experiment to use")
@click.option('--model', default = "Llama-3.2-1B-Instruct", help='model to use')
@click.option("--pretrained_model", help = "Pretrained model")
def evaluate_muse(config, experiment, model, pretrained,taskname):
    """Evaluate model on TOFU benchmark"""
    click.echo(f"Evaluating model: {model}")
    command = [
        "python src/eval.py",
        "--config-name=",config,
        "--experiment=", experiment,
        "--model=",model,
        "model.model_args.pretrained_model_name_or_path", pretrained,
        "--taskname=", taskname
    ]
    subprocess.run(command, cwd=TOFU_DIR)

if __name__ == '__main__':
    cli()
